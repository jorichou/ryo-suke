---
import { getCollection } from "astro:content";
import type { CollectionEntry } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import ContentFrame from "../components/ContentFrame.astro";
import NewsPost from "../components/NewsPost.astro";

const allNews = await getCollection('news');
const activeNews = allNews.filter((news: CollectionEntry<'news'>) => !import.meta.env.PROD || !news.data.draft);
const sortedNews = activeNews.sort((a: CollectionEntry<'news'>, b: CollectionEntry<'news'>) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const news = sortedNews;
const pageTitle = "News";
---

<BaseLayout pageTitle={pageTitle}>
    <ContentFrame chapterTitle={pageTitle} rubi="ニュース">
		<div slot="chapter-content" class="chapter-box">
			<div class="chapter-content">
				<ul class="news-list">
					{news.map((news) => <NewsPost postDate={news.data.pubDate} title={news.data.title} url={`/news/${news.slug}`} />)}
				</ul>
			</div>
		</div>
    </ContentFrame>
</BaseLayout>