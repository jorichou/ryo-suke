---
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import BlogPost from '../../components/BlogPost.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
    const allPosts = await getCollection('posts');
    const activePosts = allPosts.filter((post: CollectionEntry<'posts'>) => !import.meta.env.PROD || !post.data.draft);
    const uniqueTags = [...new Set(activePosts.map((post: CollectionEntry<'posts'>) => post.data.tags || []).flat())];
    return uniqueTags.map((tag) => {
        const filteredPosts = activePosts.filter((post: CollectionEntry<'posts'>) => (post.data.tags || []).includes(tag));
        return {
            params: { tag },
            props: { posts: filteredPosts },
        };
    });
}

const { tag } = Astro.params;
const { posts } = Astro.props;
---
<BaseLayout pageTitle={tag}>
    <p>{tag}のタグが付いた記事</p>
    <ul>
        {posts.map((post: any) => <BlogPost url={`/posts/${post.slug}`} title={post.data.title} postDate={post.data.pubDate} img_url={post.data.image?.url}/>)}
    </ul>
</BaseLayout>