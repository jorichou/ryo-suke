---
import BaseLayout from "./BaseLayout.astro";
import TableOfContents from "../components/TableOfContents.astro";
const { frontmatter, headings } = Astro.props;
---

<BaseLayout pageTitle={frontmatter.title}>
    <div class="w-box">
        <div class="about-box">
            <div class="work-description">
                <div class="title-wrap">
                    <h1>{frontmatter.title}</h1>
                    <div class="title-underline"></div>
                </div>
                <div class="table-area">
                    <div class="table-row">
                        <div class="table-header">Type</div>
                        <div class="table-content">{frontmatter.type}</div>
                    </div>
                    <div class="table-row">
                        <div class="table-header">Year</div>
                        <div class="table-content">{frontmatter.year}</div>
                    </div>
                    <div class="table-row">
                        <div class="table-header">Role</div>
                        <div class="table-content">{frontmatter.role}</div>
                    </div>
                    <div class="table-row">
                        <div class="table-header">Source</div>
                        <div class="table-content">{frontmatter.source && <a href={frontmatter.source} target="_blank" rel="noopener noreferrer">{frontmatter.source}</a>}</div>
                    </div>
                    <div class="table-row">
                        <div class="table-header">Link</div>
                        <div class="table-content">{frontmatter.link && <a href={frontmatter.link} target="_blank" rel="noopener noreferrer">{frontmatter.link}</a>}</div>
                    </div>
                </div>
                   
            </div>
            <!-- <p><em>{frontmatter.description}</em></p> -->
            <div class="work-image">
                <img src={frontmatter.image.url} width="300" alt={frontmatter.image.alt} />
            </div>
            <!-- <div class="tags">{
                frontmatter.tags.map((tag) => (
                    <p class="tag"><a href={`/tags/${tag}`}>{tag}</a></p>
                ))}
            </div> -->
        </div>
        <div class="post-layout">
            <div class="work-content">
                <slot />
            </div>
            <aside>
                <TableOfContents headings={headings} />
            </aside>
        </div>
    </div>
</BaseLayout>
<style>
    h1 {
        /* color: #707070; */
        font-size: 2rem;
        margin: 0 0 4vh 0;
        padding: 0 1vw;
    }

    .title-underline{
        border-bottom: solid #e86b79 2px;
    }

    .w-box {
        padding: 0 2rem;
        margin: 8vh 0;
    }

    a {
        color: #00539f;
    }

    .tags {
        display: flex;
        flex-wrap: wrap;
    }

    .tag {
        margin: 0.25rem;
        border: dotted 1px #a1a1a1;
        border-radius: .5rem;
        padding: .5rem 1rem;
        font-size: 1.15rem;
        background-color: #f8fcfd;
    }

    .about-box {
        display: flex;
        justify-content: space-between;
        align-items: start;
        flex-direction: row;
        margin: 0 0 10vh 0;
    }

    .work-description {
        width: 50%;
    }

    .work-image {
        width: 40%;
        display: flex;
        justify-content: center;
        align-items: center;
        border: solid #707070 2px;
        border-radius: 9px;
        aspect-ratio: 4 / 3;
        background-color: #EEEEEE;
    }

    .work-image img {
        
    }

    .table-area {
        display: flex;
        flex-direction: column;
        width: 100%;
        margin: 2vh 0;
        padding: 0 1vw;
    }

    .table-row {
        display: flex;
        flex-direction: row;
        width: 100%;
        margin-top: 2vh;
    }

    .table-header {
        width: 20%;
        font-weight: bold;
        color: #707070;
    }

    .table-content {
        width: 80%;
        color: #212121;
    }

    .table-content a {
        color: #212121;
    }
</style>